# Copy this file to .env and fill in the real values.
# .env is git-ignored and must NEVER be committed.
# In production, inject these via your secret manager / hosting platform env vars.

# ── Required ──────────────────────────────────────────────────────────────────
# Anthropic API key. Get from console.anthropic.com → API Keys.
# Production: store in AWS Secrets Manager / Railway / Heroku config vars.
ANTHROPIC_API_KEY=sk-ant-...

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Local dev:   http://localhost:5173
# Production:  https://yourapp.com
SOFIA_ALLOWED_ORIGINS=http://localhost:5173

# ── Environment flags ─────────────────────────────────────────────────────────
# SOFIA_DEBUG: 0 in production always. 1 enables Flask debug mode (never on server).
SOFIA_DEBUG=0

# SOFIA_ENV: Used by Sentry to tag events. Set to "production" on the live server.
SOFIA_ENV=development

# SOFIA_MAX_UPLOAD_MB: Max file upload size. Default 8.
SOFIA_MAX_UPLOAD_MB=8

# SOFIA_ENFORCE_CREDITS: 0 = permissive (dev). 1 = enforce credits (production,
# only after Toni's auth + billing layer is live).
SOFIA_ENFORCE_CREDITS=0

# ── Auth ──────────────────────────────────────────────────────────────────────
# Strong random secret for signing JWTs. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Must match across all backend instances. Change and all sessions invalidate.
JWT_SECRET=<generate-with-secrets.token_hex-32>
JWT_EXPIRY_HOURS=24

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string. Required for auth + credit system.
# Local dev example: postgresql://postgres:password@localhost:5432/sofia_db
DATABASE_URL=postgresql://user:password@host:5432/sofia_db

# ── Payments ─────────────────────────────────────────────────────────────────
# Paystack secret key. Get from dashboard.paystack.com → Settings → API Keys.
PAYSTACK_SECRET_KEY=sk_live_...

# Monnify credentials. Get from app.monnify.com → Settings → API Keys.
MONNIFY_API_KEY=
MONNIFY_SECRET_KEY=
MONNIFY_CONTRACT_CODE=
# Use https://api.monnify.com for live, https://sandbox.monnify.com for testing.
MONNIFY_BASE_URL=https://sandbox.monnify.com

# ── Optional monitoring ───────────────────────────────────────────────────────
# Sentry DSN. Leave blank to disable. Set in production after:
#   pip install sentry-sdk[flask]
# Get DSN from sentry.io → your project → Settings → Client Keys.
SENTRY_DSN=
