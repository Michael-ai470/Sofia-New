# Copy this file to .env and fill in the real values.
# .env is git-ignored and must NEVER be committed.
# In production, inject these via your secret manager / hosting platform env vars.

# ── Required ──────────────────────────────────────────────────────────────────
# Anthropic API key. Get from console.anthropic.com → API Keys.
# Production: store in AWS Secrets Manager / Railway / Heroku config vars.
ANTHROPIC_API_KEY=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

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Local dev:   http://localhost:5173
# Production:  https://yourapp.com
SOFIA_ALLOWED_ORIGINS=http://localhost:5173

# ── Environment flags ─────────────────────────────────────────────────────────
# SOFIA_DEBUG: 0 in production always. 1 enables Flask debug mode (never on server).
SOFIA_DEBUG=0

# SOFIA_ENV: Used by Sentry to tag events. Set to "production" on the live server.
SOFIA_ENV=development

# SOFIA_MAX_UPLOAD_MB: Max file upload size. Default 8.
SOFIA_MAX_UPLOAD_MB=8

# SOFIA_ENFORCE_CREDITS: 0 = permissive (dev). 1 = enforce credits (production,
# only after Toni's auth + billing layer is live).
SOFIA_ENFORCE_CREDITS=0

# ── Optional monitoring ───────────────────────────────────────────────────────
# Sentry DSN. Leave blank to disable. Set in production after:
#   pip install sentry-sdk[flask]
# Get DSN from sentry.io → your project → Settings → Client Keys.
SENTRY_DSN=
